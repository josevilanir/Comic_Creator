# Exemplo de configuração Nginx para Comic Creator
# Este arquivo demonstra como configurar o X-Accel-Redirect para serving eficiente de PDFs e imagens.

server {
    listen 80;
    server_name seu-dominio.com;

    # Frontend React (Build estático)
    location / {
        root /path/to/your/frontend/dist;
        index index.html;
        try_files $uri /index.html;
    }

    # API Flask (Gunicorn)
    location /api {
        proxy_pass http://127.0.0.1:5000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Redirecionamento interno para arquivos PDF e Imagens (X-Accel-Redirect)
    # IMPORTANTE: Esta location deve ser marcada como 'internal' para segurança.
    # O alias deve apontar para o diretório BASE_COMICS configurado no backend.
    location /internal_comics/ {
        internal;
        alias /home/jose/Comics/; # Substitua pelo caminho real do seu BASE_COMICS
    }

    # Configuração de upload máximo
    client_max_body_size 20M;
}
