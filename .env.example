# ============================================================
# Comic Creator — Variáveis de Ambiente do Backend
# Copie para .env e preencha os valores antes de iniciar.
# ============================================================

# ── Flask ────────────────────────────────────────────────────
FLASK_ENV=production

# Gere com: openssl rand -hex 32
SECRET_KEY=CHANGE_ME
JWT_SECRET_KEY=CHANGE_ME

# ── CORS ─────────────────────────────────────────────────────
# Domínios do frontend separados por vírgula (obrigatório em produção)
CORS_ORIGINS=https://meudominio.com,https://www.meudominio.com

# ── Armazenamento ────────────────────────────────────────────
# Caminho base onde os Comics são salvos por usuário
BASE_COMICS=/var/lib/comics

# ── Rate Limiting ─────────────────────────────────────────────
# Sem Redis, o limite é por worker (não compartilhado entre workers).
# Configure Redis para limites globais com múltiplos workers Gunicorn.
REDIS_URL=redis://localhost:6379/0

# ── Downloads ────────────────────────────────────────────────
MAX_CONCURRENT_DOWNLOADS=4

# ── Registro de usuários ─────────────────────────────────────
# Defina como False para desabilitar registro público
ALLOW_PUBLIC_REGISTRATION=True

# Se definido, todo novo registro deve fornecer este código
# INVITE_CODE=seu-codigo-secreto

# ── Nginx / X-Accel-Redirect ─────────────────────────────────
# Ative para que o Nginx sirva os arquivos diretamente (mais eficiente)
USE_X_ACCEL_REDIRECT=False
# Deve corresponder à location 'internal' no nginx.conf
X_ACCEL_PREFIX=/internal_comics/

# ── Object Storage — S3 / Cloudflare R2 (opcional) ───────────
# Deixe em branco para usar o filesystem local
# S3_BUCKET=comic-creator
# S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=auto
# S3_PRESIGNED_EXPIRY=3600

# ── Gunicorn (opcional — também pode ser passado via CLI) ─────
# GUNICORN_WORKERS=5
# GUNICORN_BIND=0.0.0.0:5000
# GUNICORN_TIMEOUT=120
# GUNICORN_LOG_LEVEL=info

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
